# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=<your-wallet-private-key>

# ── Solana RPC ─────────────────────────────────────────────────────────────
RPC_URL=<your-helius-rpc-url-with-api-key>
RPC_FALLBACK_URL=https://solana-rpc.publicnode.com

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_BASE_URL=<your-llm-base-url>
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=<your-model>

# ── Jupiter API (opsional, tanpa key juga jalan) ─────────────────
JUPITER_API_KEY=

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=<your-helius-api-key>
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
